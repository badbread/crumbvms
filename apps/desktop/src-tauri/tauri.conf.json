{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrumbVMS",
  "version": "0.0.1",
  "identifier": "video.crumb.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CrumbVMS",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob: http: https:",
        "media-src": "'self' data: blob: http: https:",
        "connect-src": "'self' http: https: ws: wss:",
        "frame-src": "http: https:",
        "font-src": "'self' data:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libmpv2",
          "libgtk-3-0",
          "libwebkit2gtk-4.1-0",
          "libepoxy0",
          "libegl1"
        ]
      }
    }
  }
}
