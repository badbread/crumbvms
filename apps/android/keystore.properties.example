# Template for local release signing. Copy this file to
# apps/android/keystore.properties (gitignored — never commit the real one)
# and fill in real values to build a signed release APK/AAB locally with
# `./gradlew assembleRelease` / `bundleRelease`.
#
# storeFile may be an absolute path, or relative to apps/android/ (this file's
# directory).
#
# To generate a NEW real release keystore (do this ONCE, then back it up
# somewhere durable — losing it means you can never update the app under the
# same applicationId again):
#
#   keytool -genkeypair -v \
#     -keystore crumb-release.jks \
#     -alias crumb \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -storetype PKCS12
#
# It will prompt for a store password, a key password, and identity fields
# (name/org/etc — any values are fine, they end up in the cert).
#
# CI (.github/workflows/android-release.yml) does NOT read this file — it
# reads the equivalent CRUMB_RELEASE_KEYSTORE_PATH / _PASSWORD / _KEY_ALIAS /
# _KEY_PASSWORD environment variables, sourced from GitHub Actions secrets
# (see that workflow's header comment for the exact secret names to set).

storeFile=crumb-release.jks
storePassword=CHANGE_ME
keyAlias=crumb
keyPassword=CHANGE_ME
